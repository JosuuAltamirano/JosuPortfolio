---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Página no encontrada · Josué Altamirano"
  description="Esta página no existe."
>
  <main class="not-found">
    <div class="terminal">
      <span class="prompt">josue@odemstudio</span>
      <span class="sep">:</span>
      <span class="path">~/portfolio</span>
      <span class="cmd">$ cd <span class="arg">esta-pagina</span></span>
    </div>
    <p class="error">bash: esta-pagina: No existe el fichero o directorio</p>
    <h1 class="code">404</h1>
    <p class="msg">Esta página no existe.</p>
    <a href="/" class="back">← Volver al inicio</a>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
  }
  .terminal {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .prompt { color: var(--mint); }
  .sep { color: var(--text-muted); }
  .path { color: var(--blue); }
  .cmd { color: var(--text-muted); }
  .arg { color: var(--peach); }
  .error {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--peach);
  }
  .code {
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 700;
    background: linear-gradient(135deg, var(--text) 0%, var(--mint) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .msg { color: var(--text-muted); font-size: 1rem; }
  .back {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--mint);
    border: 1px solid rgba(148, 226, 213, 0.3);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    margin-top: 0.5rem;
    transition: background 0.2s, border-color 0.2s;
  }
  .back:hover { background: rgba(148, 226, 213, 0.1); border-color: var(--mint); }
</style>

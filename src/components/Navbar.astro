<style>
  .navbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .navbar-inner {
    max-width: 56rem; margin: 0 auto; padding: 0.75rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .navbar-logo {
    font-family: var(--font-mono);
    font-size: 0.875rem; color: var(--mint); font-weight: 600;
  }
  .navbar-links { display: flex; gap: 1.5rem; align-items: center; }
  .navbar-links a {
    font-size: 0.8rem; color: var(--text-muted);
    font-family: var(--font-mono); transition: color 0.2s;
  }
  .navbar-links a:hover { color: var(--mint); }
  .nav-social { display: flex; gap: 0.5rem; }
  .nav-social a {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem; border: 1px solid var(--border);
    border-radius: 8px; color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s;
  }
  .nav-social a:hover { color: var(--mint); border-color: var(--mint); }
  @media (max-width: 640px) { .navbar-links { display: none; } }
</style>